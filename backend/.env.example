# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
FLASK_DEBUG=0
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — zero config, good for development)
# DATABASE_URL=sqlite:///quishing_guard.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/quishing_guard

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-deploying
JWT_EXPIRY_HOURS=24

# ── Analysis engine ───────────────────────────────────────────────────────────
MAX_REDIRECT_HOPS=10
RESOLVER_TIMEOUT=5
CORS_ORIGINS=*

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Omit for in-memory (resets on restart, single process only)
# REDIS_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=logs/quishing_guard.log
